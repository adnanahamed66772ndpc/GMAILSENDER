# Gmail যেই অ্যাকাউন্ট দিয়ে ইমেইল পাঠাবেন
GMAIL_USER=your.email@gmail.com

# ইনবক্সে যাওয়ার জন্য: প্রাপককে আপনার নাম যেভাবে দেখাবে (খালি রাখলে "Gmail Sender")
GMAIL_FROM_NAME=আপনার নাম

# Gmail App Password (Google Account থেকে তৈরি করুন, সাধারণ পাসওয়ার্ড নয়)
# কিভাবে পাবেন: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: পোর্ট (ডিফল্ট 3000)
# PORT=3000

# Bulk + Unsubscribe: লাইভ সাইটে আনসাবস্ক্রাইব লিংক সঠিক URL এ যাবে
# BASE_URL=https://yourdomain.com

# Bulk পাঠানোর মধ্যে প্রতিটি ইমেইলের গ্যাপ (ms) – Gmail রেট লিমিট এড়াতে
# BULK_DELAY_MS=400
